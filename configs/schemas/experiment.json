{
  "$id": "https://example.com/experiment-configuration.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExperimentConfiguration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "target": { "type": ["string", "null"] },
    "experiments_directory_root": { "type": "string" },
    "name": { "type": "string" },
    "seed": { "type": "integer" },

    "dataset_train": { "$ref": "#/$defs/DynamicModuleConfigBase" },
    "dataset_test": { "$ref": "#/$defs/DynamicModuleConfigBase" },
    "dataset_postprocessing": {
      "anyOf": [
        { "$ref": "#/$defs/DynamicModuleConfigBase" },
        { "type": "null" }
      ]
    },

    "partitioning": {
      "oneOf": [
        { "$ref": "#/$defs/DynamicModuleConfigBase" },
        {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/DynamicModuleConfigBase" }
        }
      ]
    },

    "graph": { "$ref": "#/$defs/DynamicModuleConfigBase" },
    "local_model": { "$ref": "#/$defs/DynamicModuleConfigBase" },
    "scenario": { "$ref": "#/$defs/DynamicModuleConfigBase" },

    "paiv": { "$ref": "#/$defs/PaivModuleConfig" },

    "callbacks": {
      "type": "array",
      "items": { "$ref": "#/$defs/DynamicModuleConfigBase" },
      "default": []
    }
  },
  "required": [
    "experiments_directory_root",
    "name",
    "seed",
    "dataset_train",
    "dataset_test",
    "partitioning",
    "graph",
    "local_model",
    "scenario",
    "paiv"
  ],

  "$defs": {
    "DynamicModuleConfigBase": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target": { "type": "string" },
        "arguments": {
          "type": ["object", "null"],
          "description": "Free-form keyword arguments for the target."
        }
      },
      "required": ["target"]
    },

    "PaivModuleConfig": {
      "allOf": [
        { "$ref": "#/$defs/DynamicModuleConfigBase" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "training_engine": { "$ref": "#/$defs/DynamicModuleConfigBase" }
          },
          "required": ["training_engine"]
        }
      ]
    }
  }
}
